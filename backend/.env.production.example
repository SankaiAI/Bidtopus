# ── Production environment — fill in after deploying ──────────────────────────
#
# SETUP STEPS:
# 1. Go to dashboard.clerk.com → outcomex app → switch to Production
# 2. Enter your deployment domain (e.g. api.outcomeX.com or your Railway URL)
# 3. Complete DNS verification (add the CNAME Clerk shows you)
# 4. Copy sk_live_... and pk_live_... keys below
# 5. Copy this file to .env.production (never commit that file)
#
# Then run: clerk env pull --instance prod --app app_3Dgj3DsPlDzXTStd1qiIoO0rwv8 --file .env.production
# (once Clerk CLI Platform API auth is fixed, this will auto-fill the keys)

# Neon PostgreSQL — prod branch (separate from dev)
# Project: outcomex | branch: main (prod)
DATABASE_URL=postgresql://neondb_owner:<password>@ep-old-hill-ajp821gw-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require

# Clerk — production instance keys (sk_live_... prefix)
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Meta Ads
META_ADS_ACCESS_TOKEN=...
META_ADS_ACCOUNT_ID=act_...

# Circle
CIRCLE_API_KEY=...

# Agent service — replace with Railway URL once deployed
AGENT_BASE_URL=https://outcomex-agent.up.railway.app

# App
ENVIRONMENT=production
ALLOWED_ORIGINS=https://your-production-domain.com
