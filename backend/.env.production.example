# ── Production environment — fill in after deploying ──────────────────────────
#
# SETUP STEPS:
# 1. Go to dashboard.clerk.com → outcomex app → switch to Production
# 2. Enter your deployment domain (e.g. api.outcomeX.com or your Railway URL)
# 3. Complete DNS verification (add the CNAME Clerk shows you)
# 4. Copy sk_live_... and pk_live_... keys below
# 5. Copy this file to .env.production (never commit that file)
#
# Then run: clerk env pull --instance prod --app app_3Dgj3DsPlDzXTStd1qiIoO0rwv8 --file .env.production
# (once Clerk CLI Platform API auth is fixed, this will auto-fill the keys)
#
# Boot-time guards that will REFUSE to start if misconfigured:
# - ALLOWED_ORIGINS must not contain localhost / 127.0.0.1 / "*" when ENVIRONMENT != development
# - ARC_RPC_URL + ESCROW_CONTRACT_ADDRESS must be set, or every fund-escrow call returns 503
# - AGENT_SERVICE_TOKEN must match the same env var on the agent service

# Neon PostgreSQL — prod branch (separate from dev)
# Project: outcomex | branch: main (prod)
DATABASE_URL=postgresql://neondb_owner:<password>@ep-old-hill-ajp821gw-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require

# Clerk — production instance keys (sk_live_... prefix)
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Meta Ads
META_ADS_ACCESS_TOKEN=...
META_ADS_ACCOUNT_ID=act_...

# Circle
CIRCLE_API_KEY=...

# Arc / contracts — REQUIRED in production. Without these, _verify_fund_tx_onchain
# fails closed with 503 on every funding attempt (per issue C-1 fix). Either fill
# both or accept that fund-escrow is broken.
# ARC_RPC_URL: run `arc-canteen login && arc-canteen rpc-url`
ARC_RPC_URL=
# ESCROW_CONTRACT_ADDRESS: copy from contracts/out/address.json after deploy
ESCROW_CONTRACT_ADDRESS=

# Agent service — replace with the agent's Railway URL once deployed
AGENT_BASE_URL=https://outcomex-agent.up.railway.app

# Shared service-to-service token for backend↔agent calls (issues #79, #85).
# Generate with: openssl rand -hex 32
# MUST be set to the same value on both backend AND agent .env. If only one
# side has it set, mutual-auth fails on every cross-service call.
AGENT_SERVICE_TOKEN=

# SIWE wallet-connect (issue #84). The frontend signs messages with this exact
# domain string — must equal the production frontend host without scheme,
# e.g. "outcomex-frontend.up.railway.app" or "app.outcomex.com". A mismatch
# 400s every wallet-connect attempt.
SIWE_DOMAIN=
# Arc chain id the SIWE message must declare. 5042002 = Arc testnet.
ARC_CHAIN_ID=5042002
# Nonce lifetime in seconds (default 300 = 5 min).
SIWE_NONCE_TTL_SECONDS=300

# App
ENVIRONMENT=production
# CRITICAL: must be the actual production frontend URL(s), comma-separated.
# Default value here uses localhost on purpose — if you forget to override it,
# the CORS startup guard (L-1) raises RuntimeError and the app refuses to
# boot. Replace with your real frontend host(s) before deploying.
ALLOWED_ORIGINS=http://localhost:3000
