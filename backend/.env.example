# Neon PostgreSQL - use the POOLED connection string
# Project: bidtopus (crimson-salad-15768812)
# dev  branch -> ep-plain-band-ajxf5b08-pooler.c-3.us-east-2.aws.neon.tech
# prod branch -> ep-old-hill-ajp821gw-pooler.c-3.us-east-2.aws.neon.tech
DATABASE_URL=postgresql://neondb_owner:<password>@ep-plain-band-ajxf5b08-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require

# Clerk - server-side JWT verification
CLERK_SECRET_KEY=sk_test_...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Meta Ads — NOT NEEDED ON BACKEND.
# Only the agent component talks to Meta Ads MCP. Backend just passes
# identifiers (contract_id, merchant_id, meta_ads_account_id) over to the agent
# via agent_client; the agent uses its own META_ADS_ACCESS_TOKEN to do the
# actual Marketing API calls. Set these in agent/.env, not here.
# (META_ADS_ACCOUNT_ID was historically used as a global default — since #76
# each contract has its own meta_ads_accounts.meta_ads_account_id row.)

# Circle
CIRCLE_API_KEY=...

# Arc / contracts - on-chain tx verification (skipped with warning when unset)
# Public RPC: https://rpc.testnet.arc.network
ARC_RPC_URL=
# Copy from contracts/out/address.json after deploy
ESCROW_CONTRACT_ADDRESS=

# Agent service
AGENT_BASE_URL=http://localhost:8001

# Shared secret for agent → backend service-to-service calls (e.g. performance ingest).
# Must match the same env var on the agent side. Generate with: `openssl rand -hex 32`
AGENT_SERVICE_TOKEN=

# SIWE wallet-connect (issue #84). Domain that the SIWE message must declare —
# frontend signs with this host. Must match the public-facing frontend host.
SIWE_DOMAIN=localhost:3000
# Arc chain id the SIWE message must declare. Testnet = 5042002.
ARC_CHAIN_ID=5042002
# How long a wallet-connect nonce is valid for, in seconds.
SIWE_NONCE_TTL_SECONDS=300

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
