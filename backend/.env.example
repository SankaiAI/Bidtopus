# Neon PostgreSQL — use the POOLED connection string
# Project: outcomex (crimson-salad-15768812)
# dev  branch → ep-plain-band-ajxf5b08-pooler.c-3.us-east-2.aws.neon.tech
# prod branch → ep-old-hill-ajp821gw-pooler.c-3.us-east-2.aws.neon.tech
DATABASE_URL=postgresql://neondb_owner:<password>@ep-plain-band-ajxf5b08-pooler.c-3.us-east-2.aws.neon.tech/neondb?sslmode=require

# Clerk — server-side JWT verification
CLERK_SECRET_KEY=sk_test_...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Meta Ads
META_ADS_ACCESS_TOKEN=...
META_ADS_ACCOUNT_ID=act_...

# Circle
CIRCLE_API_KEY=...

# Arc / contracts — used to verify fund() tx hashes on-chain before marking contract Funded
# Leave blank during local dev — verification is skipped with a warning when unset.
# Required for demo / production — set both to enable real on-chain verification.
# Public RPC: https://rpc.testnet.arc.network
ARC_RPC_URL=
# Copy from contracts/out/address.json after deploy
ESCROW_CONTRACT_ADDRESS=

# Agent service
AGENT_BASE_URL=http://localhost:8001

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
