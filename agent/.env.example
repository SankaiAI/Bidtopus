# LLM
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Database (Neon or local Postgres — shared with backend)
DATABASE_URL=postgresql://user:password@host/dbname

# Meta Ads (required when META_ADS_MOCK=False)
META_ADS_ACCESS_TOKEN=

# Circle Wallets (required when CIRCLE_MOCK=False)
CIRCLE_API_KEY=
CIRCLE_WALLET_SET_ID=
AGENT_WALLET_ID=

# Arc / Web3 (required when ARC_MOCK=False)
# Run: arc-canteen login && arc-canteen rpc-url  (binary at C:\Users\ariel\.local\bin\)
# Public fallback RPC: https://rpc.testnet.arc.network
ARC_RPC_URL=
# ESCROW_CONTRACT_ADDRESS: populated from contracts/out/address.json after deploy
ESCROW_CONTRACT_ADDRESS=
# CIRCLE_BLOCKCHAIN: Circle's blockchain ID for Arc testnet
CIRCLE_BLOCKCHAIN=ARC-TESTNET

# Backend push (agent → backend)
# BACKEND_BASE_URL: where the backend listens. Defaults to localhost for dev.
BACKEND_BASE_URL=http://localhost:8000
# AGENT_SERVICE_TOKEN: shared secret for the X-Service-Token header. Must match
# backend's AGENT_SERVICE_TOKEN env var or every push will 401/403.
AGENT_SERVICE_TOKEN=

# Monitoring scheduler — interval in minutes between performance ticks.
# 15 is the sweet spot for Meta Ads Insights lag. Drop to 5 for demos.
MONITORING_TICK_MINUTES=15

# Mock flags
# True  → local development / unit testing. No real API calls. Fake tx hashes returned.
#          Contract data still saves to Postgres. Safe to use without any API keys.
# False → demo / production. Real USDC moves on Arc. Real Circle Wallets API calls made.
#          Requires CIRCLE_API_KEY, AGENT_WALLET_ID, ENTITY_SECRET, ARC_RPC_URL,
#          and ESCROW_CONTRACT_ADDRESS to be set before switching off.
META_ADS_MOCK=True   # set False when META_ADS_ACCESS_TOKEN is ready
ARC_MOCK=True        # set False for demo — real on-chain settlement
CIRCLE_MOCK=True     # set False for demo — real Circle Wallets API signing

# Decision thresholds (defaults shown — only set to override)
# ACCEPT_THRESHOLD=0.65
# COUNTER_LOW=0.35
# COUNTER_HIGH=0.64
# REJECT_THRESHOLD=0.35
# MAX_NEGOTIATION_TURNS=5
# AUTO_APPROVE_BUDGET_PCT=0.15
# APPROVAL_REQUIRED_BUDGET_PCT=0.30
