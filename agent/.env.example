# LLM
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# Database (Neon or local Postgres — shared with backend)
DATABASE_URL=postgresql://user:password@host/dbname

# Meta Ads (required when META_ADS_MOCK=False)
META_ADS_ACCESS_TOKEN=

# Circle Wallets (required when CIRCLE_MOCK=False)
CIRCLE_API_KEY=
CIRCLE_WALLET_SET_ID=
AGENT_WALLET_ID=

# Arc / Web3 (required when ARC_MOCK=False)
ARC_RPC_URL=
ESCROW_CONTRACT_ADDRESS=

# Mock flags — all True by default for local development
META_ADS_MOCK=True
ARC_MOCK=True
CIRCLE_MOCK=True

# Decision thresholds (defaults shown — only set to override)
# ACCEPT_THRESHOLD=0.65
# COUNTER_LOW=0.35
# COUNTER_HIGH=0.64
# REJECT_THRESHOLD=0.35
# MAX_NEGOTIATION_TURNS=5
# AUTO_APPROVE_BUDGET_PCT=0.15
# APPROVAL_REQUIRED_BUDGET_PCT=0.30
