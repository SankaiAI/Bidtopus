# ── Arc Testnet ───────────────────────────────────────────────────────────────
# Run: arc-canteen login && arc-canteen rpc-url
# (arc-canteen is installed via uv, binary at C:\Users\ariel\.local\bin\arc-canteen.exe)
# Public fallback RPC: https://rpc.testnet.arc.network
ARC_RPC_URL=

# ── Deployment ────────────────────────────────────────────────────────────────
# Private key of the account used to deploy (use a throwaway key, not your main wallet)
DEPLOYER_PRIVATE_KEY=0x

# USDC token contract address on Arc testnet
# Verify at: https://arc-node.thecanteenapp.com or Circle's Arc testnet docs
USDC_TOKEN_ADDRESS=

# The authorized settler address — the only address allowed to call release() or refund().
# This is the agent's Circle Wallet address (from agent/.env AGENT_WALLET_ID → wallet address).
# Get it by running: arc-canteen login && checking agent Circle wallet
SETTLER_ADDRESS=
